{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "openmd",
  "version": "0.0.1",
  "identifier": "dev.skxv.openmd",
  "build": {
    "beforeDevCommand": "pnpm run dev:server",
    "devUrl": "http://127.0.0.1:3000/launcher",
    "beforeBuildCommand": "pnpm --filter web build",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "openmd",
        "width": 900,
        "height": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
