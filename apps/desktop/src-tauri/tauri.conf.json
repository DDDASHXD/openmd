{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "foliage",
  "version": "0.0.4",
  "identifier": "dev.skxv.foliage",
  "build": {
    "beforeDevCommand": "node scripts/dev.mjs",
    "devUrl": "http://127.0.0.1:5173/launcher",
    "beforeBuildCommand": "node scripts/tauri-before-build.mjs",
    "frontendDist": "../../client/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "foliage",
        "url": "/launcher",
        "width": 900,
        "height": 600,
        "resizable": true,
        "dragDropEnabled": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:* https://foliage.skxv.dev wss://foliage.skxv.dev; img-src 'self' http://127.0.0.1:* data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/node"
    ],
    "resources": [
      "resources/foliage-server/bin/**/*",
      "resources/foliage-server/lib/**/*",
      "resources/foliage-server/src/**/*",
      "resources/foliage-server/package.json",
      "resources/foliage-server/node_modules/**/*"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
