{
  "name": "foliage",
  "version": "0.0.4",
  "private": false,
  "bin": {
    "foliage-server": "./packages/foliage-server/bin/foliage-server.mjs",
    "foliage-relay": "./packages/foliage-relay/bin/foliage-relay.mjs",
    "foliage-relay-client": "./packages/foliage-relay/bin/foliage-relay-client.mjs"
  },
  "dependencies": {
    "foliage-server": "workspace:*",
    "@foliage/relay": "workspace:*"
  },
  "scripts": {
    "build": "pnpm --filter client build",
    "dev": "pnpm --filter desktop dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "desktop:dev": "pnpm --filter desktop dev",
    "desktop:build": "pnpm --filter desktop build",
    "server:headless": "foliage-server --headless --workspace ./test-workspace --port 8787 --hostname 0.0.0.0",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/sync-version.mjs --check",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
